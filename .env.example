# Backend: connection string de PostgreSQL para desarrollo local o Railway.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/estacionamiento

# Backend: secreto largo para firmar JWT. Cambiar en cada ambiente real.
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio

# Backend: puerto local de la API.
PORT=3000

# Backend: ambiente de ejecucion. Usar production en Railway.
NODE_ENV=development

# Backend: origen permitido para CORS durante desarrollo local.
CORS_ORIGIN=http://localhost:5173

# Frontend: URL base de la API consumida por Vite.
VITE_API_URL=http://localhost:3000/api/v1
